      "boundElements": null,
      "updated": 1773913307514,
      "link": null,
      "locked": false,
      "text": "SERVICE - IUserService / UserServiceImpl\n  CreateProfileAsync()   →  checks duplicate AuthUserId, saves profile\n  GetProfileAsync()      →  fetch profile by AuthUserId\n  SubmitKycAsync()       →  checks duplicate, saves with Status = Pending\n  GetKycStatusAsync()    →  fetch KYC by AuthUserId",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SERVICE - IUserService / UserServiceImpl\n  CreateProfileAsync()   →  checks duplicate AuthUserId, saves profile\n  GetProfileAsync()      →  fetch profile by AuthUserId\n  SubmitKycAsync()       →  checks duplicate, saves with Status = Pending\n  GetKycStatusAsync()    →  fetch KYC by AuthUserId",
      "autoResize": true,
      "lineHeight": 1.25
    },
