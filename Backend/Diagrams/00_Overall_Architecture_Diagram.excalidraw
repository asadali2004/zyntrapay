    {
      "id": "Iuj3E0T7CuydNbxDG3U5A",
      "type": "text",
      "x": 511.79998779296875,
      "y": 1426.5999755859375,
      "width": 338.80236622065325,
      "height": 126.40002441406251,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b00",
      "roundness": null,
      "seed": 1537442915,
      "version": 61,
      "versionNonce": 1113370819,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1773913307514,
      "link": null,
      "locked": false,
      "text": "KYC STATUS FLOW\n  Pending  →  Approved  (by Admin via AdminService)\n  Pending  →  Rejected  (by Admin via AdminService, reason required)\n  Once Approved or Rejected → cannot be changed again\n\nNOTES\n  - AuthUserId is NOT a database foreign key\n  - Separate databases cannot have cross-DB FK constraints\n  - Relationship is enforced at application level only\n  - User can only access their own profile (extracted from JWT)",
      "fontSize": 10.112001953124999,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "KYC STATUS FLOW\n  Pending  →  Approved  (by Admin via AdminService)\n  Pending  →  Rejected  (by Admin via AdminService, reason required)\n  Once Approved or Rejected → cannot be changed again\n\nNOTES\n  - AuthUserId is NOT a database foreign key\n  - Separate databases cannot have cross-DB FK constraints\n  - Relationship is enforced at application level only\n  - User can only access their own profile (extracted from JWT)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "q-DTEk5kzTb8nRiknX0N0",
      "type": "rectangle",
      "x": 403.79998779296875,
      "y": 787.1999664306641,
      "width": 660.7999877929688,
      "height": 1100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b01",
      "roundness": {
        "type": 3
      },
      "seed": 2108661859,
      "version": 269,
      "versionNonce": 1915043235,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773913414092,
