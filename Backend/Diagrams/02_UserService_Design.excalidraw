      "updated": 1773912704577,
      "link": null,
      "locked": false,
      "text": "CONTROLLER - UserController\n  Attribute: [Authorize] — valid JWT required for all endpoints\n  AuthUserId always extracted from JWT token, never from request body\n\n  POST /api/user/profile   →  CreateProfile()\n  GET  /api/user/profile   →  GetProfile()\n  POST /api/user/kyc       →  SubmitKyc()\n  GET  /api/user/kyc       →  GetKycStatus()",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CONTROLLER - UserController\n  Attribute: [Authorize] — valid JWT required for all endpoints\n  AuthUserId always extracted from JWT token, never from request body\n\n  POST /api/user/profile   →  CreateProfile()\n  GET  /api/user/profile   →  GetProfile()\n  POST /api/user/kyc       →  SubmitKyc()\n  GET  /api/user/kyc       →  GetKycStatus()",
      "autoResize": true,
      "lineHeight": 1.25
    },
