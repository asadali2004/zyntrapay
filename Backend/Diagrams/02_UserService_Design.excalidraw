      "versionNonce": 1681867021,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773912536559,
      "link": null,
      "locked": false,
      "text": "NOTES\n  - BCrypt handles salting internally, no separate password table needed\n  - Admin registration protected by AdminSecretKey from appsettings.json\n  - JWT is stateless — every other service validates it independently\n  - Same SecretKey, Issuer, Audience must be used across all services",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "NOTES\n  - BCrypt handles salting internally, no separate password table needed\n  - Admin registration protected by AdminSecretKey from appsettings.json\n  - JWT is stateless — every other service validates it independently\n  - Same SecretKey, Issuer, Audience must be used across all services",
      "autoResize": true,
      "lineHeight": 1.25
    },
