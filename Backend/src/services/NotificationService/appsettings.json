{
  "ConnectionStrings": {
    "NotificationDB": "Server=localhost\\SQLEXPRESS;Database=NotificationDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Issuer": "ZyntraPayApp",
    "Audience": "ZyntraPay.NotificationService",
    "ExpiryMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    }
  },
  "RabbitMQ": { "Host": "localhost" },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "EmailSettings": {
    "Port": 587,
    "FromName": "ZyntraPay"
  }
}