{
  "ConnectionStrings": {
    "WalletDB": "Server=localhost\\SQLEXPRESS;Database=WalletDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Issuer": "ZyntraPayApp",
    "Audience": "ZyntraPay.WalletService",
    "ExpiryMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    }
  },
  "RabbitMQ": { "Host": "localhost" },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  }
}